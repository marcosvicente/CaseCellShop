{
  "name": "casecellshop-backend",
  "version": "1.0.0",
  "description": "CaseCellShop backend challenge — catalog cache, async checkout, observability",
  "type": "module",
  "scripts": {
    "dev": "USE_IN_MEMORY=true tsx watch src/server.ts",
    "dev:redis": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "async-mutex": "^0.5.0",
    "bullmq": "^5.34.8",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
